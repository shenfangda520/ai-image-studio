{
  "$schema": "https://raw.githubusercontent.com/nicholasrice/tauri/refs/heads/dev/crates/tauri-config-schema/schema.json",
  "productName": "AI Image Studio",
  "version": "1.0.0",
  "identifier": "com.ai-image-studio.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Image Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "http": {
      "scope": {
        "allow": ["http://**", "https://**"]
      }
    }
  }
}
